{
  "xsappname": "hsn-app",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Classifier",
      "description": "View queue and run classification"
    },
    {
      "name": "$XSAPPNAME.Approver",
      "description": "Approve HSN classifications"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Administer the HSN service"
    }
  ],
  "role-templates": [
    {
      "name": "Classifier",
      "description": "Review materials and trigger batch",
      "scope-references": [
        "$XSAPPNAME.Classifier"
      ]
    },
    {
      "name": "Approver",
      "description": "Approve classifications",
      "scope-references": [
        "$XSAPPNAME.Classifier",
        "$XSAPPNAME.Approver"
      ]
    },
    {
      "name": "Admin",
      "description": "Full administration",
      "scope-references": [
        "$XSAPPNAME.Classifier",
        "$XSAPPNAME.Approver",
        "$XSAPPNAME.Admin"
      ]
    }
  ]
}
